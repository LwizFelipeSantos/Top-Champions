rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} { allow read, write: if false; }

    function isValidId(id) { 
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() 
        && request.auth.token.email.lower() == 'luizfelipengl@gmail.com'
        && request.auth.token.email_verified == true; 
    }

    // TEAM VALIDATION
    function isValidTeam(data) {
      return data.keys().hasAll(['name', 'createdAt', 'updatedAt']) 
        && data.keys().size() <= 6
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && (data.get('color', '') is string && data.get('color', '').size() <= 20)
        && (data.get('imageUrl', '') is string && data.get('imageUrl', '').size() <= 300000)
        && data.createdAt is timestamp 
        && data.updatedAt is timestamp;
    }

    match /teams/{teamId} {
      allow read: if true;
      allow delete: if isAdmin() && isValidId(teamId);
      
      allow create: if isAdmin() 
        && isValidId(teamId)
        && isValidTeam(incoming()) 
        && incoming().createdAt == request.time 
        && incoming().updatedAt == request.time;
        
      allow update: if (
        isAdmin() 
        && isValidId(teamId)
        && isValidTeam(incoming())
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'color', 'imageUrl', 'updatedAt'])
      );
    }

    // PLAYER VALIDATION
    function isValidPlayer(data) {
      return data.keys().hasAll(['teamId', 'name', 'createdAt', 'updatedAt']) 
        && data.keys().size() <= 5
        && data.teamId is string && data.teamId.size() <= 128
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && (data.get('number', '') is string && data.get('number', '').size() <= 10)
        && data.createdAt is timestamp 
        && data.updatedAt is timestamp;
    }

    match /players/{playerId} {
      allow read: if true;
      allow delete: if isAdmin() && isValidId(playerId);
      
      allow create: if isAdmin() 
        && isValidId(playerId)
        && isValidPlayer(incoming()) 
        && incoming().createdAt == request.time 
        && incoming().updatedAt == request.time
        && exists(/databases/$(database)/documents/teams/$(incoming().teamId));
        
      allow update: if (
        isAdmin() 
        && isValidId(playerId)
        && isValidPlayer(incoming())
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && incoming().teamId == existing().teamId
        && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'number', 'updatedAt'])
      );
    }

    // MATCH VALIDATION
    function isValidMatch(data) {
      return data.keys().hasAll(['round', 'homeTeamId', 'awayTeamId', 'status', 'date', 'createdAt', 'updatedAt']) 
        && data.keys().size() <= 10
        && data.round is number 
        && data.homeTeamId is string && data.homeTeamId.size() <= 128
        && data.awayTeamId is string && data.awayTeamId.size() <= 128
        && (data.get('homeScore', null) == null || data.get('homeScore', null) is number)
        && (data.get('awayScore', null) == null || data.get('awayScore', null) is number)
        && data.status in ['scheduled', 'finished']
        && data.date is string && data.date.size() <= 50
        && data.createdAt is timestamp 
        && data.updatedAt is timestamp;
    }

    match /matches/{matchId} {
      allow read: if true;
      allow delete: if isAdmin() && isValidId(matchId);
      
      allow create: if isAdmin() 
        && isValidId(matchId)
        && isValidMatch(incoming()) 
        && incoming().createdAt == request.time 
        && incoming().updatedAt == request.time
        && exists(/databases/$(database)/documents/teams/$(incoming().homeTeamId))
        && exists(/databases/$(database)/documents/teams/$(incoming().awayTeamId));
        
      allow update: if (
        isAdmin() 
        && isValidId(matchId)
        && isValidMatch(incoming())
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && incoming().homeTeamId == existing().homeTeamId
        && incoming().awayTeamId == existing().awayTeamId
        && (
          (incoming().diff(existing()).affectedKeys().hasOnly(['round', 'date', 'updatedAt', 'homeScore', 'awayScore', 'status']))
        )
      );
    }
  }
}
